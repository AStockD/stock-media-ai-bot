# Stock Media AI Bot - Environment Variables

# Database
DB_HOST=your_db_host
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=smab
ASTOCKD_DB_NAME=astockd

# JWT Authentication
JWT_SECRET=your_jwt_secret

# Stock Analysis API (stock-diagnosis-app)
STOCK_ANALYZE_URL=http://your_host:8888
STOCK_ANALYZE_BEARER_TOKEN=your_bearer_token

# astockd.com Poster API
ASTOCKD_POSTER_API_TOKEN=your_poster_token

# LLM (OpenAI-compatible API)
LLM_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=your_llm_api_key
LLM_MODEL=qwen-plus
